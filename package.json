{
  "name": "vigilfit",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "api": "node backend/server.js",
    "api:memory": "node backend/dev-memory-api.js",
    "test:api": "node --test backend/tests/*.test.js",
    "e2e:mobile:seed": "node backend/tests/e2e-mobile-setup.js",
    "test:e2e:mobile:auth": "maestro test e2e/maestro/auth-flow.yaml",
    "test:e2e:mobile:logging": "maestro test e2e/maestro/logging-flow.yaml",
    "test:e2e:mobile:ai": "maestro test e2e/maestro/ai-flow.yaml",
    "test:e2e:mobile": "npm run e2e:mobile:seed && npm run test:e2e:mobile:auth && npm run test:e2e:mobile:logging && npm run test:e2e:mobile:ai",
    "validate:submission": "npm run lint && npx tsc --noEmit && npm run test:api",
    "validate:submission:full": "npm run validate:submission && npm run test:e2e:mobile",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "android:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-android-dev.ps1",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
